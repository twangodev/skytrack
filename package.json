		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/d3-scale": "^4.0.9",
		"@types/d3-shape": "^3.1.8",
		"@types/node": "^24",
		"d3-scale": "^4.0.2",
		"d3-shape": "^3.2.0",
		"layerchart": "^1.0.13",
		"mode-watcher": "^1.1.0",
		"png-to-ico": "^3.0.1",
		"prettier": "^3.8.3",
